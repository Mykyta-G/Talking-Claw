# Agent API endpoint
# This is the HTTP API your agent bridge talks to.
# Point it at whatever backend you use (custom agent API, proxy, etc.)
# See agent_bridge.py for the expected HTTP contract.
AGENT_API_URL=http://YOUR_AGENT_API_HOST:3456

# Auth token for the agent API (leave blank if none required)
GATEWAY_TOKEN=

# Agent ID sent with each request (your backend decides what this means)
AGENT_ID=assistant

# Voice settings
# Available Kokoro voices: bm_lewis, am_michael, am_adam, af_heart, af_bella
DEFAULT_VOICE=bm_lewis

# Per-agent voice mapping (JSON)
# Map agent IDs to Kokoro voice IDs for multi-agent setups
VOICE_MAP={"assistant":"bm_lewis","helper":"am_adam"}

# Pipeline server settings
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=8790

# Whisper STT settings
WHISPER_MODEL=distil-medium.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en

# Voice activity detection
VAD_THRESHOLD=0.5

# Voice system prompt (injected into agent context for calls)
VOICE_SYSTEM_PROMPT=You are in a LIVE VOICE CALL. Your text is being spoken aloud. Keep responses to 1-3 sentences. Use contractions. Speak naturally. No markdown, no bullet points, no code blocks. If asked about code or long content, say you will send it in chat. Match your personality but keep it CONCISE.
