# =============================================================================
# Talking-Claw Voice Pipeline -- Configuration
# =============================================================================
# Copy this to .env and fill in your values.
#
# Two modes:
#   Recommended: STT_BACKEND=groq + TTS_BACKEND=piper (no GPU needed)
#   GPU Local:   STT_BACKEND=local + TTS_BACKEND=kokoro (needs NVIDIA GPU)
# =============================================================================

# -- Backend Selection --------------------------------------------------------
# Which STT and TTS engines to use.
# Recommended: groq + piper (runs on Pi 5 / NUC / old laptop, no GPU)
# GPU Local:   local + kokoro (needs NVIDIA GPU with 6+ GB VRAM)

STT_BACKEND=groq
TTS_BACKEND=piper

# -- Agent API ----------------------------------------------------------------
# The HTTP endpoint your agent bridge talks to.
# Point it at whatever backend you use (custom agent API, proxy, etc.)
# See agent_bridge.py for the expected HTTP contract.
AGENT_API_URL=http://YOUR_AGENT_API_HOST:3456

# Auth token for the agent API (leave blank if none required)
GATEWAY_TOKEN=

# Agent ID sent with each request (your backend decides what this means)
AGENT_ID=assistant

# -- Groq STT (recommended) --------------------------------------------------
# Free API key from https://console.groq.com
# Free tier: 28,800 audio-seconds/day (enough for ~50 calls/day)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# -- Local Whisper STT (GPU mode) --------------------------------------------
# Only used when STT_BACKEND=local
WHISPER_MODEL=distil-medium.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en

# -- Piper TTS (recommended) -------------------------------------------------
# Local CPU-based TTS. Free, fast (~100ms), no internet needed after model download.
# Voice list: https://rhasspy.github.io/piper-samples/
# Good defaults: en_US-ryan-high, en_US-lessac-high, en_GB-alba-medium
PIPER_VOICE=en_US-ryan-high

# Directory to store downloaded voice models (default: pipeline/models/)
PIPER_DOWNLOAD_DIR=

# Set to true if you have a GPU and want faster Piper inference
PIPER_USE_CUDA=false

# -- Kokoro TTS (GPU mode) ---------------------------------------------------
# Only used when TTS_BACKEND=kokoro
# Available voices: bm_lewis, am_michael, am_adam, af_heart, af_bella
DEFAULT_VOICE=bm_lewis

# Per-agent voice mapping (JSON) for multi-agent setups
VOICE_MAP={"assistant":"bm_lewis","helper":"am_adam"}

# -- Pipeline Server ----------------------------------------------------------
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=8790

# -- Voice Activity Detection -------------------------------------------------
VAD_THRESHOLD=0.5

# -- Voice System Prompt ------------------------------------------------------
# Injected into agent context for calls
VOICE_SYSTEM_PROMPT=You are in a LIVE VOICE CALL. Your text is being spoken aloud. Keep responses to 1-3 sentences. Use contractions. Speak naturally. No markdown, no bullet points, no code blocks. If asked about code or long content, say you will send it in chat. Match your personality but keep it CONCISE.
