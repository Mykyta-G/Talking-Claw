# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your main Telegram user ID (the person the AI calls)
# Find yours: message @userinfobot on Telegram
TARGET_USER_ID=

# 2FA password for the AI's Telegram account (if set)
TELEGRAM_2FA_PASSWORD=

# Pipeline server address
# With the recommended setup (Groq + Piper), both the caller and pipeline
# run on the same machine (Pi 5, NUC, etc.), so use localhost.
# If running the pipeline on a separate GPU server, use its IP instead.
PIPELINE_HOST=localhost
PIPELINE_WS_PORT=8790
PIPELINE_HEALTH_PORT=8790

# Wake-on-LAN (optional, only needed if pipeline is on a separate machine)
# MAC address of pipeline server's network interface
WOL_MAC_ADDRESS=
# Broadcast address for WoL packet (default: 255.255.255.255)
WOL_BROADCAST=255.255.255.255

# Agent ID passed to the pipeline on call start
AGENT_ID=assistant
CALL_REASON=
