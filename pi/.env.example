# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your main Telegram user ID (the person the AI calls)
# Find yours: message @userinfobot on Telegram
TARGET_USER_ID=

# 2FA password for the AI's Telegram account (if set)
TELEGRAM_2FA_PASSWORD=

# Forge GPU server address (Tailscale or LAN IP)
FORGE_HOST=100.85.217.17
FORGE_WS_PORT=8790
FORGE_HEALTH_PORT=8790

# Wake-on-LAN for Forge (optional)
# MAC address of Forge's network interface
FORGE_MAC_ADDRESS=
# Broadcast address for WoL packet
FORGE_BROADCAST=100.85.255.255

# Agent context (passed to pipeline on call start)
AGENT_ID=wizard
CALL_REASON=
